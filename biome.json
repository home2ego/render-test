{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",

  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },

  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },

  "css": {
    "parser": {
      "cssModules": true
    }
  },

  "html": {
    "formatter": {
      "enabled": true
    }
  },

  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  }
}
